{
  "manifest_version": 3,
  "name": "WebSense",
  "version": "0.1.0",
  "description": "Checks navigations and warns before suspicious sites load.",
  "permissions": [
    "storage",
    "tabs",
    "webNavigation",
    "alarms"
  ],
  "host_permissions": [
    "<all_urls>",
    "http://127.0.0.1:*/*",
    "http://localhost:*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "WebSense"
  },
  "web_accessible_resources": [
    {
      "resources": ["interstitial.html", "report.html", "dashboard.html"],
      "matches": ["<all_urls>"]
    }
  ]
}
